PORT=3001
PYTHON_SERVICE_URL=http://localhost:8000
NODE_ENV=development
REQUEST_TIMEOUT_MS=10000
RETRY_TIMES=1

LLM_ENABLED=true
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
LLM_TIMEOUT_MS=8000
LLM_RETRY_TIMES=1

ANSWER_ENHANCEMENT_ENABLED=true
QUERY_REWRITE_ENABLED=true
RAG_LLM_QUERY_ENABLED=false
RAG_ENABLED=true

RAG_RERANK_ENABLED=false
RAG_EMBEDDING_CACHE_ENABLED=false
RAG_EMBEDDING_PROVIDER=openai
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_CACHE_PATH=../evaluation/cache/rag_embeddings.json
RAG_RERANK_CANDIDATE_LIMIT=8
RAG_EMBEDDING_DIMENSIONS=96
